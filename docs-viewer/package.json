{
  "name": "docs-viewer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run copy-docs",
    "copy-docs": "cp -r ../docs dist/ && cp -r ../co-creation dist/ && cp -r ../research dist/ && cp ../README.md dist/ROOT_README.md",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/svelte": "5.3.1",
    "jsdom": "29.0.2",
    "svelte": "^5.55.1",
    "vite": "^8.0.4",
    "vitest": "4.1.4"
  },
  "dependencies": {
    "@types/three": "0.183.1",
    "marked": "18.0.0",
    "three": "0.183.2"
  }
}
